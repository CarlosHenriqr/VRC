# Resend — serviço de envio de e-mails (https://resend.com)
# 1. Crie uma conta em resend.com
# 2. Vá em "API Keys" e gere uma nova chave
# 3. Copie este arquivo para .env e preencha os valores abaixo
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# E-mail que receberá as mensagens do formulário de contato
# Em modo teste (sem domínio verificado), use o MESMO e-mail da conta Resend
CONTACT_EMAIL=tech.cora.dev@gmail.com

# Opcional: remetente verificado no Resend (domínio próprio)
# Sem configurar, será usado onboarding@resend.dev (apenas para testes)
# FROM_EMAIL=tech.cora.dev@gmail.com

# Firebase Analytics (público no client — prefixo VITE_ obrigatório)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
