# Resend — serviço de envio de e-mails (https://resend.com)
# 1. Crie uma conta em resend.com
# 2. Vá em "API Keys" e gere uma nova chave
# 3. Cole abaixo e renomeie este arquivo para .env
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# E-mail que receberá as mensagens do formulário de contato
CONTACT_EMAIL=seu@email.com

# Opcional: e-mail de origem verificado no Resend (domínio próprio)
# Sem configurar, será usado o domínio padrão do Resend
# FROM_EMAIL=contato@vrc.com.br
